<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Simple Restaurant Website</title>

<!-- Bootstrap CSS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

</head>
<body>

<!-- Navbar -->
<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
  <div class="container">
    <a class="navbar-brand" href="#">Food Corner</a>
  </div>
</nav>

<!-- Welcome Section -->
<div class="container text-center mt-5">
  <h1>Welcome to Food Corner</h1>
  <p>Enjoy our delicious food</p>
</div>

<!-- Menu Section -->
<div class="container mt-4">
  <div class="row">

    <div class="col-md-4">
      <div class="card">
        <img src="https://via.placeholder.com/300" class="card-img-top">
        <div class="card-body text-center">
          <h5>Burger</h5>
          <p>Tasty beef burger</p>
          <button class="btn btn-primary">Order</button>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card">
        <img src="https://via.placeholder.com/300" class="card-img-top">
        <div class="card-body text-center">
          <h5>Pizza</h5>
          <p>Cheesy hot pizza</p>
          <button class="btn btn-primary">Order</button>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card">
        <img src="https://via.placeholder.com/300" class="card-img-top">
        <div class="card-body text-center">
          <h5>Ice Cream</h5>
          <p>Sweet dessert</p>
          <button class="btn btn-primary">Order</button>
        </div>
      </div>
    </div>

  </div>
</div>

<!-- Contact Section -->
<div class="bg-light text-center p-4 mt-5">
  <h4>Contact Us</h4>
  <p>Phone: +63 912 345 6789</p>
  <p>Email: foodcorner@email.com</p>
</div>

<!-- Footer -->
<footer class="bg-dark text-white text-center p-3">
  <p>© 2026 Food Corner</p>
</footer>

</body>
</html>
